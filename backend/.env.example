# Smart Diagram Studio - Environment Configuration Example
# Rename this file to .env and fill in your API keys

# Server Configuration
PORT=5005

# AI API Keys (At least one is required)
GROQ_API_KEY=your_groq_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# Email Configuration (For Feedback feature)
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_email_app_password

# Firebase Configuration (Optional, for cloud sync)
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=
